rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    function isAdmin() {
      return signedIn() && request.auth.token.admin == true;
    }

    function isOwner(uid) {
      return signedIn() && request.auth.uid == uid;
    }

    match /settings/{docId} {
      allow read: if docId == "restaurant";
      allow write: if isAdmin();
    }

    match /categories/{categoryId} {
      allow read: if resource.data.isActive == true || isAdmin();
      allow write: if isAdmin();
    }

    match /menuItems/{itemId} {
      allow read: if resource.data.isActive != false || isAdmin();
      allow write: if isAdmin();
    }

    match /users/{uid} {
      allow create: if isOwner(uid)
        && request.resource.data.authType == "anonymous";
      allow read, update: if isOwner(uid) || isAdmin();
      allow delete: if isAdmin();
    }

    match /orders/{orderId} {
      allow read: if isAdmin() || (signedIn() && resource.data.customerUid == request.auth.uid);
      allow create: if false;
      allow update: if isAdmin();
      allow delete: if isAdmin();
    }

    match /analyticsDaily/{dayId} {
      allow read, write: if isAdmin();
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
